rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /toilets/{toiletId} {
      allow read: if true;
      allow write: if false;
    }

    match /reviews/{reviewId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
