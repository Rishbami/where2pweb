rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAccessibilityList(value) {
      return value is list
        && value.size() <= 3
        && value.hasOnly(["wheelchair", "baby-changing", "gender-neutral"]);
    }

    function isValidToiletCreate() {
      return request.resource.data.keys().hasOnly([
          "name",
          "description",
          "address",
          "location",
          "rating",
          "reviewCount",
          "accessibility",
          "openingHours",
          "photosCount",
          "searchKeywords",
          "createdByUserId",
          "createdByEmail",
          "createdAt",
          "updatedAt",
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.address is string
        && request.resource.data.address.size() >= 5
        && request.resource.data.openingHours is string
        && request.resource.data.openingHours.size() >= 3
        && request.resource.data.rating is number
        && request.resource.data.rating >= 0
        && request.resource.data.rating <= 5
        && request.resource.data.reviewCount == 0
        && request.resource.data.photosCount == 0
        && request.resource.data.accessibility is list
        && isAccessibilityList(request.resource.data.accessibility)
        && request.resource.data.searchKeywords is list
        && request.resource.data.location is map
        && request.resource.data.location.lat is number
        && request.resource.data.location.lng is number
        && request.resource.data.createdByUserId == request.auth.uid
        && (
          request.resource.data.createdByEmail == null
          || request.resource.data.createdByEmail == request.auth.token.email
        );
    }

    match /toilets/{toiletId} {
      allow read: if true;
      allow create: if request.auth != null && isValidToiletCreate();
      allow update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
